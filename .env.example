# ─────────────────────────────────────────────────────────────────────────────
# Contoso Outdoors demo — environment configuration
# Copy this file to `.env` and fill in the values for the backend you want.
#   cp .env.example .env
# Switch backends any time by changing MODEL_BACKEND (great as a stage fallback).
# ─────────────────────────────────────────────────────────────────────────────

# Which model backend to use: azure-openai | foundry | github | openai
MODEL_BACKEND=azure-openai

# Stream traces to the Foundry Toolkit local collector (VS Code). true|false
ENABLE_TRACING=false

# ── Azure OpenAI (primary for this talk) ─────────────────────────────────────
# Auth: if AZURE_OPENAI_API_KEY is set it is used; otherwise Entra ID via `az login`.
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-10-21
# AZURE_OPENAI_API_KEY=your-key-here      # optional; prefer `az login` for demos

# ── Microsoft Foundry (project endpoint) ─────────────────────────────────────
# Uses Entra ID (az login). Set MODEL_BACKEND=foundry to use this.
FOUNDRY_PROJECT_ENDPOINT=https://YOUR-RESOURCE.services.ai.azure.com/api/projects/YOUR-PROJECT
FOUNDRY_MODEL=gpt-4o-mini

# ── GitHub Models (zero-Azure fallback) ──────────────────────────────────────
# Free with a GitHub PAT. Set MODEL_BACKEND=github to use this on stage in a pinch.
GITHUB_TOKEN=ghp_your_token_here
GITHUB_MODEL=openai/gpt-4o-mini
GITHUB_MODELS_ENDPOINT=https://models.github.ai/inference

# ── OpenAI (or any OpenAI-compatible endpoint) ───────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
